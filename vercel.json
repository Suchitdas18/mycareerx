{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "admin.html",
            "use": "@vercel/static"
        },
        {
            "src": "sitemap.xml",
            "use": "@vercel/static"
        },
        {
            "src": "robots.txt",
            "use": "@vercel/static"
        },
        {
            "src": "career-counselling.html",
            "use": "@vercel/static"
        },
        {
            "src": "direct-admission.html",
            "use": "@vercel/static"
        },
        {
            "src": "career-guidance-after-12th.html",
            "use": "@vercel/static"
        },
        {
            "src": "logomycareerx.png",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/server.js"
        },
        {
            "src": "/admin",
            "dest": "/admin.html"
        },
        {
            "src": "/admin.html",
            "dest": "/admin.html"
        },
        {
            "src": "/sitemap.xml",
            "dest": "/sitemap.xml"
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt"
        },
        {
            "src": "/career-counselling",
            "dest": "/career-counselling.html"
        },
        {
            "src": "/career-counselling.html",
            "dest": "/career-counselling.html"
        },
        {
            "src": "/direct-admission",
            "dest": "/direct-admission.html"
        },
        {
            "src": "/direct-admission.html",
            "dest": "/direct-admission.html"
        },
        {
            "src": "/career-guidance-after-12th",
            "dest": "/career-guidance-after-12th.html"
        },
        {
            "src": "/career-guidance-after-12th.html",
            "dest": "/career-guidance-after-12th.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}